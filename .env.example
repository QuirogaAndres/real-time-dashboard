# =============================================
#  Variables de entorno — dashboard en tiempo real
# =============================================
#
#  1. Copia este archivo y renómbralo como .env
#  2. Reemplaza los valores con tus keys reales
#  3. Agrega .env a tu .gitignore (¡nunca subas las keys a GitHub!)
#
# =============================================

# OpenWeatherMap → https://openweathermap.org/api
# Plan gratuito: 1000 llamadas/día
VITE_OPENWEATHER_KEY=tu_key_aqui

# GNews → https://gnews.io
# Plan gratuito: 100 llamadas/día
VITE_GNEWS_KEY=tu_key_aqui

# ¿Por qué VITE_ al inicio?
# Vite solo expone al navegador las variables que empiezan con VITE_
# Las que no tienen ese prefijo quedan solo en el servidor (más seguro)
